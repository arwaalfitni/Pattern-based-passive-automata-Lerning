digraph G {
  rankdir=LR;
  node [shape=circle, style=filled, fillcolor=white];
  "0" [isInitial=True, fillcolor=red, shape=doublecircle];
  "1" [fillcolor=red, shape=doublecircle];
  "2" [fillcolor=red, shape=doublecircle];
  "3" [fillcolor=red, shape=doublecircle];
  "5" [fillcolor=red, shape=doublecircle];
  "9" [fillcolor=red, shape=doublecircle];
  "10" [fillcolor=red, shape=doublecircle];
  "17" [fillcolor=red, shape=doublecircle];
  "0" -> "1" [label="L1/X\nL2/X"];
  "0" -> "17" [label="L0/X"];
  "1" -> "2" [label="L2/X\nL0/X"];
  "1" -> "9" [label="L1/X"];
  "2" -> "3" [label="L2/X"];
  "2" -> "9" [label="L0/Y\nL1/Y"];
  "3" -> "5" [label="L0/X"];
  "3" -> "3" [label="L1/X"];
  "5" -> "2" [label="L0/X"];
  "5" -> "10" [label="L1/Y"];
  "9" -> "10" [label="L0/Y\nL2/Y"];
  "10" -> "10" [label="L0/Y\nL2/Y\nL1/Y"];
  "17" -> "9" [label="L0/Y"];
  "17" -> "5" [label="L2/X"];
}