  "32" [fillcolor=red, shape=doublecircle];
  "71" [fillcolor=red, shape=doublecircle];
  "0" -> "1" [label="L1/X"];
  "0" -> "17" [label="L0/X"];
  "0" -> "32" [label="L2/X"];
  "1" -> "0" [label="L2/X"];
  "1" -> "1" [label="L1/X"];
  "1" -> "71" [label="L0/Y"];
  "4" -> "5" [label="L0/X"];
  "4" -> "71" [label="L2/Y"];
  "5" -> "5" [label="L0/X"];
  "5" -> "4" [label="L2/X"];
  "5" -> "71" [label="L1/Y"];
  "17" -> "17" [label="L2/X"];
  "17" -> "71" [label="L0/Y\nL1/Y"];
  "32" -> "4" [label="L1/X"];
  "32" -> "17" [label="L0/X\nL2/X"];
  "71" -> "71" [label="L1/Y\nL2/Y\nL0/Y"];
}